{
  "name": "photo-dedup-desktop-shell",
  "private": true,
  "version": "0.1.1",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "build": {
    "appId": "io.github.lisyoen.photodedup",
    "productName": "PhotoDedup",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/sidecar",
        "to": "sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
